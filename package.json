{
  "name": "cybersygn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-pdfs": "python3 scripts/generate-pdfs.py",
    "generate-pdfs:vision": "python3 scripts/generate-vision-pdfs.py",
    "generate-pdfs:comprehensive": "python3 scripts/generate-comprehensive-pdfs.py",
    "generate-pdfs:all": "npm run generate-pdfs && npm run generate-pdfs:vision && npm run generate-pdfs:comprehensive",
    "test": "node scripts/run-detection.js",
    "test:vision": "node scripts/probe-vision-pdfs.mjs",
    "test:comprehensive": "node scripts/probe-comprehensive-pdfs.mjs",
    "test:real": "node scripts/run-real-detection.js",
    "test:bulk": "node scripts/run-bulk-detection.mjs",
    "test:all-synthetic": "npm run test && npm run test:vision && npm run test:comprehensive",
    "test:worker": "node scripts/test-multi-signer.js",
    "test:stripe": "node scripts/test-stripe.js",
    "test:docx": "node scripts/test-docx-pipeline.js",
    "test:templates": "node scripts/test-templates.js",
    "build:templates": "node scripts/generate-templates.js",
    "vendor": "node scripts/vendor.js",
    "preview": "node scripts/serve-web.js",
    "build": "npm run smoke && node scripts/build-blog-cache.mjs && node scripts/build-use-cases.mjs && node scripts/build-comparisons.mjs && node scripts/build-web.js",
    "build:compare": "node scripts/build-comparisons.mjs",
    "build:web": "npm run smoke && node scripts/build-web.js",
    "build:seo": "node scripts/build-use-cases.mjs",
    "build:blog": "node scripts/build-blog-cache.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "lint:css": "node scripts/css-check.mjs",
    "lint": "npm run smoke && npm run lint:css",
    "deploy": "npm run lint && npm run build && npm run test:worker && npx wrangler deploy"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.0.20",
    "@fontsource/inter": "^5.0.18",
    "@fontsource/jetbrains-mono": "^5.0.20",
    "mammoth": "^1.12.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "4.0.379"
  },
  "devDependencies": {
    "docx": "^9.7.0"
  }
}
